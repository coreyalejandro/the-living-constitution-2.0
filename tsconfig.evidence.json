{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist/evidence-chain",
    "rootDir": "src/evidence-chain",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": false,
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true
  },
  "include": ["src/evidence-chain/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
