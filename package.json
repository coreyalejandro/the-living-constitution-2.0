{
  "name": "the-living-constitution-2.0",
  "version": "1.0.0",
  "description": "Runtime enforcement layer for the SocioTechnical Constitution. Implements the Policy Engine, Evidence Observatory, Contract Window, Role Authorizer, Break-Glass Override, and Integrated Verification workflow.",
  "license": "MIT",
  "type": "module",
  "main": "src/core/contract-manager.js",
  "bin": {
    "tlc": "./scripts/tlc.mjs",
    "tlc-cli": "./src/cli/tlc-cli.js"
  },
  "scripts": {
    "start": "node scripts/tlc.mjs",
    "validate": "node src/cli/tlc-cli.js validate",
    "status": "node src/cli/tlc-cli.js status",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit",
    "test:integration": "node --test tests/integration/*.test.mjs",
    "test:compliance": "jest tests/compliance",
    "schema:validate": "ajv validate -s schemas/contract-schema.json -d contracts/active/BUILD_CONTRACT.json",
    "contracts:workbench:validate": "node scripts/validate-workbench-contracts.mjs",
    "contracts:workbench:schema": "node scripts/validate-workbench-contracts.mjs --schema-only",
    "contracts:workbench:check": "npm run contracts:workbench:schema && npm run contracts:workbench:validate",
    "lint": "eslint src/ --ext .js,.jsx",
    "dev": "node --watch src/cli/tlc-cli.js status",
    "verify": "npm run validate && npm test -- --runInBand",
    "scan:projects": "node scripts/scan-projects.mjs",
    "verify:registry": "node scripts/verify-registry.mjs",
    "generate:module-status": "node scripts/generate-module-status.mjs",
    "generate:portfolio-data": "node scripts/generate-portfolio-data.mjs",
    "ingest:verify": "npm run verify:registry && npm run generate:module-status && npm run generate:portfolio-data",
    "sync:portfolio": "node scripts/sync-portfolio-data.mjs",
    "tlc:work": "node scripts/tlc-work.mjs",
    "tlc:done": "node scripts/tlc-done.mjs",
    "tlc:new": "node scripts/tlc-new.mjs",
    "tlc:dashboard": "node scripts/tlc-dashboard.mjs",
    "tlc:context": "node scripts/inject-ai-context.mjs",
    "tlc:validate": "python scripts/validate_repo.py",
    "tlc:register": "node scripts/tlc-register.mjs",
    "tlc:report": "node scripts/tlc-report.mjs",
    "tlc:sync-skills": "node scripts/tlc-sync-skills.mjs",
    "tlc:hermes": "node scripts/tlc-hermes.mjs",
    "tlc:purge": "node scripts/tlc-purge.mjs",
    "tlc:health": "node scripts/tlc-health.mjs",
    "tlc:audit-retention": "node scripts/tlc-audit-retention.mjs",
    "tlc:setup": "node scripts/tlc-setup.mjs",
    "tlc:sl": "node tlc-sl/src/compile.mjs --target check",
    "tlc:sl:compile": "node tlc-sl/src/compile.mjs --target all",
    "tlc:sl:test": "node --test tlc-sl/tests/*.test.mjs",
    "tlc:sl:conformance": "node tlc-sl/src/conformance.mjs",
    "tlc:sl:evidence": "node tlc-sl/src/record-evidence.mjs",
    "tlc:sl:sign-evidence": "node tlc-sl/src/sign-evidence.mjs",
    "tlc:sl:verify-evidence": "node src/core/evidence-chain.mjs verify evidence/TLC-SL/verification.signed.jsonl evidence/TLC-SL/evidence-public-key.pem",
    "evidence:test": "node --test src/core/evidence-chain.test.mjs",
    "evidence:verify": "node src/core/evidence-chain.mjs verify evidence/signed-demo/governance.jsonl evidence/signed-demo/public-key.pem",
    "evidence:root": "node src/core/evidence-chain.mjs root evidence/signed-demo/governance.jsonl",
    "probe-gate:test": "node --test probe-gate/tests/*.test.mjs",
    "probe-gate:check": "node probe-gate/src/cli.mjs",
    "ii:check": "node tlc-sl/src/compile.mjs constitutions/instructional-integrity/spec --target check",
    "constitutions:check": "node constitutions/check-platform.mjs",
    "tlc": "node scripts/tlc.mjs",
    "tlc:tui": "node --import tsx/esm src/tui/app.tsx",
    "test:evidence": "node --import tsx/esm --test src/evidence-chain/engine.test.ts"
  },
  "keywords": [
    "governance",
    "constitution",
    "policy-engine",
    "evidence",
    "contract",
    "crsp",
    "sociotechnical",
    "compliance"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "express": "^5.2.1",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "js-yaml": "^4.1.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "c8": "^11.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "transform": {}
  }
}