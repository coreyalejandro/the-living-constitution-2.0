{
  "name": "sociotechnical-constitution-runtime",
  "version": "1.0.0",
  "description": "Runtime enforcement layer for the SocioTechnical Constitution. Implements the Policy Engine, Evidence Observatory, Contract Window, Role Authorizer, Break-Glass Override, and Integration Adaptors.",
  "license": "MIT",
  "type": "module",
  "main": "src/core/contract-manager.js",
  "bin": {
    "tlc-cli": "./src/cli/tlc-cli.js"
  },
  "scripts": {
    "start": "node src/cli/tlc-cli.js",
    "validate": "node src/cli/tlc-cli.js validate",
    "status": "node src/cli/tlc-cli.js status",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:compliance": "jest tests/compliance",
    "schema:validate": "ajv validate -s schemas/contract-schema.json -d contracts/active/BUILD_CONTRACT.json",
    "lint": "eslint src/ --ext .js,.jsx",
    "dev": "node --watch src/cli/tlc-cli.js status",
    "verify": "npm run validate && npm test -- --runInBand",
    "scan:projects": "node scripts/scan-projects.mjs",
    "verify:registry": "node scripts/verify-registry.mjs",
    "generate:module-status": "node scripts/generate-module-status.mjs",
    "generate:portfolio-data": "node scripts/generate-portfolio-data.mjs",
    "ingest:verify": "npm run verify:registry && npm run generate:module-status && npm run generate:portfolio-data"
  },
  "keywords": [
    "governance",
    "constitution",
    "policy-engine",
    "evidence",
    "contract",
    "crsp",
    "sociotechnical",
    "compliance"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
