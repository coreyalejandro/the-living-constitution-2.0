---------------------------- MODULE INV_001 ----------------------------
\* GENERATED by the TLC-SL compiler from INV-001 — Contract before promotion.
\* Article VIII.1 / IV.3. Enforcement BLOCK.
\* STATUS: emitted, NOT yet checked by TLC in this build. See tla.mjs header.
EXTENDS TLC

VARIABLES contract, status
vars == << contract, status >>

TypeOK ==
  /\ contract \in { "none", "active", "frozen" }
  /\ status \in { "unverified", "partial", "working" }

Init ==
  /\ contract = "none"
  /\ status = "unverified"

Op_BIND_CONTRACT ==
  /\ TRUE
  /\ contract' = "active"
  /\ UNCHANGED << status >>

Op_FREEZE_CONTRACT ==
  /\ (contract = "active")
  /\ contract' = "frozen"
  /\ UNCHANGED << status >>

Op_PROMOTE_PARTIAL ==
  /\ TRUE
  /\ status' = "partial"
  /\ UNCHANGED << contract >>

Op_PROMOTE_WORKING ==
  /\ (contract # "none")
  /\ status' = "working"
  /\ UNCHANGED << contract >>

Next ==
  \/ Op_BIND_CONTRACT
  \/ Op_FREEZE_CONTRACT
  \/ Op_PROMOTE_PARTIAL
  \/ Op_PROMOTE_WORKING

Spec == Init /\ [][Next]_vars

\* Safety property (Constitution VIII.1 / IV.3):
Safety == ((status = "working") => (contract # "none"))
