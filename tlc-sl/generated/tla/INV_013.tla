\* GENERATED by the TLC-SL compiler from INV-013 — Partial may not display as working.
\* Article VIII.2 / II.5. Enforcement BLOCK.
\* STATUS: emitted, NOT yet checked by TLC in this build. See tla.mjs header.
EXTENDS TLC

VARIABLES truth, pds
vars == << truth, pds >>

TypeOK ==
  /\ truth \in { "partial", "other" }
  /\ pds \in { "demo", "working" }

Init ==
  /\ truth = "partial"
  /\ pds = "demo"

Op_SET_TRUTH_OTHER ==
  /\ TRUE
  /\ truth' = "other"
  /\ UNCHANGED << pds >>

Op_SET_TRUTH_PARTIAL ==
