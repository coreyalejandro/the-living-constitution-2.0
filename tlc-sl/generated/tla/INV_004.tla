---------------------------- MODULE INV_004 ----------------------------
\* GENERATED by the TLC-SL compiler from INV-004 — Frozen contract admits no new acceptance criteria.
\* Article VIII.1 / IV.2. Enforcement BLOCK.
\* STATUS: emitted, NOT yet checked by TLC in this build. See tla.mjs header.
EXTENDS TLC

VARIABLES contract, breach
vars == << contract, breach >>

TypeOK ==
  /\ contract \in { "active", "frozen" }
  /\ breach \in { "ok", "violated" }

Init ==
  /\ contract = "active"
  /\ breach = "ok"

Op_FREEZE ==
  /\ TRUE
  /\ contract' = "frozen"
  /\ UNCHANGED << breach >>

Op_ADD_AC ==
  /\ (contract # "frozen")
  /\ breach' = (IF (contract = "frozen") THEN "violated" ELSE breach)
  /\ UNCHANGED << contract >>

Next ==
  \/ Op_FREEZE
  \/ Op_ADD_AC

Spec == Init /\ [][Next]_vars

\* Safety property (Constitution VIII.1 / IV.2):
Safety == (breach = "ok")
