{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "crsp-workbench-contract.schema.json",
  "title": "TLC Workbench Contract Schema",
  "description": "Strict schema for a machine-readable TLC Workbench contract.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schema_version",
    "contract_id",
    "stable_id",
    "contract_kind",
    "status",
    "issue_reference",
    "title",
    "human_contract_path",
    "binds_module",
    "goal",
    "objective",
    "relationships",
    "required_files",
    "required_outputs",
    "acceptance_criteria",
    "halt_conditions",
    "evidence_requirements",
    "vt_requirements"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "../../../schemas/contracts/crsp-workbench-contract.schema.json"
    },
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "contract_id": {
      "type": "string",
      "pattern": "^CRSP-TLC-WORKBENCH(?:-[A-Z]+)?-001$"
    },
    "stable_id": {
      "type": "string",
      "pattern": "^tlc-workbench\\.[a-z0-9.-]+$"
    },
    "contract_kind": {
      "type": "string",
      "enum": ["parent", "child"]
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Active", "Frozen", "Superseded", "Archived"]
    },
    "issue_reference": {
      "type": "string",
      "const": "coreyalejandro/the-living-constitution-2.0#15"
    },
    "title": {
      "type": "string",
      "minLength": 10
    },
    "human_contract_path": {
      "type": "string",
      "pattern": "^contracts/active/CRSP-TLC-WORKBENCH(?:-[A-Z]+)?-001\\.md$"
    },
    "binds_module": {
      "type": "string",
      "pattern": "^TLC-WORKBENCH(?:-[A-Z]+)?$"
    },
    "goal": {
      "type": "string",
      "minLength": 20
    },
    "objective": {
      "type": "string",
      "minLength": 40
    },
    "relationships": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parent_contract_id", "child_contract_ids", "dependency_contract_ids"],
      "properties": {
        "parent_contract_id": {
          "type": "string",
          "pattern": "^CRSP-[A-Z0-9-]+$"
        },
        "child_contract_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^CRSP-[A-Z0-9-]+$"
          },
          "uniqueItems": true
        },
        "dependency_contract_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^CRSP-[A-Z0-9-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "required_files": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "required_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/acceptanceCriterion"
      }
    },
    "halt_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/haltCondition"
      }
    },
    "evidence_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/evidenceRequirement"
      }
    },
    "vt_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_fields", "note"],
      "properties": {
        "required_fields": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["EXISTS", "VERIFIED AGAINST", "NOT CLAIMED", "FUNCTIONAL STATUS"]
          },
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true
        },
        "note": {
          "type": "string",
          "minLength": 20
        }
      }
    }
  },
  "definitions": {
    "acceptanceCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "verification"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^AC-WB-[A-Z0-9-]+$"
        },
        "statement": {
          "type": "string",
          "minLength": 15
        },
        "verification": {
          "type": "string",
          "minLength": 15
        }
      }
    },
    "haltCondition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "trigger", "resolution", "severity"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^HALT_WB_[A-Z0-9_]+$"
        },
        "trigger": {
          "type": "string",
          "minLength": 20
        },
        "resolution": {
          "type": "string",
          "minLength": 15
        },
        "severity": {
          "type": "string",
          "enum": ["warn", "block", "critical"]
        }
      }
    },
    "evidenceRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "artifacts"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^EV-WB-[A-Z0-9-]+$"
        },
        "description": {
          "type": "string",
          "minLength": 20
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 3
          }
        }
      }
    }
  }
}
