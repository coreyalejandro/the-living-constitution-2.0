      "op": "=",
      "l": {
        "t": "var",
        "name": "delivery"
      },
      "r": {
        "t": "lit",
        "value": "delivered"
      }
    },
    "r": {
      "t": "eq",
      "op": "=",
      "l": {
        "t": "var",
        "name": "a11y"
      },
      "r": {
        "t": "lit",
        "value": "present"
      }
    }
  }
