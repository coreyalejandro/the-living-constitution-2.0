{
  "id": "II-005",
  "title": "Accessible rendering required before delivery",
  "article": "Instructional Integrity / UDL",
  "level": "BLOCK",
  "rationale": "Instructional content may not be delivered to a learner without an accessibility-conformant rendering available.",
  "stateVars": [
    "a11y",
    "delivery"
  ],
  "inputVars": [],
  "domains": {
    "a11y": [
      "absent",
      "present"
    ],
    "delivery": [
      "blocked",
      "delivered"
    ]
  },
  "initState": {
    "a11y": "absent",
    "delivery": "blocked"
  },
  "ops": [
