{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "session_schema.json",
  "title": "Research Session",
  "description": "A single data-collection session in the research study.",
  "type": "object",
  "required": ["session_id", "date", "session_type"],
  "additionalProperties": false,
  "properties": {
    "session_id": {
      "type": "string",
      "description": "Unique session identifier (e.g. C1L4, S001)"
    },
    "date": {
      "type": "string",
      "description": "ISO 8601 date (YYYY-MM-DD)",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "start_time": {
      "type": ["string", "null"],
      "description": "HH:MM start time or MISSING"
    },
    "end_time": {
      "type": ["string", "null"],
      "description": "HH:MM end time or MISSING"
    },
    "duration_minutes": {
      "type": ["integer", "string", "null"],
      "description": "Session duration in minutes or MISSING"
    },
    "session_type": {
      "type": "string",
      "enum": ["prospective", "retrospective", "incomplete"],
      "description": "Whether this session was logged in real time or recovered"
    },
    "construct_scores": {
      "type": "object",
      "description": "Post-session construct ratings (1-5 or MISSING)",
      "additionalProperties": {
        "type": ["integer", "string"]
      }
    },
    "notes": {
      "type": "string",
      "description": "Post-session observation notes (researcher's own words only)"
    },
    "recovery_confidence": {
      "type": ["integer", "string", "null"],
      "description": "Retrospective only: confidence in recall 1-5 or MISSING"
    },
    "recovery_date": {
      "type": ["string", "null"],
      "description": "Retrospective only: ISO 8601 date of recovery entry or MISSING"
    },
    "events": {
      "type": "array",
      "description": "Events logged during this session",
      "items": { "$ref": "event_schema.json" }
    }
  }
}
